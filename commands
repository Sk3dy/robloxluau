local function getRequiredMineTime(resourceModel)
	local baseTime = resourceModel:GetAttribute("BaseMineTime") or 5.0
	local toolPower = 1 -- Defaults to bare hands speed

	-- 🔍 DYNAMIC TOOL CHECKER:
	local character = player.Character
	local equippedTool = character and character:FindFirstChildOfClass("Tool")

	if equippedTool then
		-- Pull the dynamic speed attribute from the tool instance (defaults to 1 if missing)
		toolPower = equippedTool:GetAttribute("MiningSpeed") or 1
		print("🎒 CLIENT MATH: Found equipped tool '" .. equippedTool.Name .. "' with ToolPower: " .. tostring(toolPower))
	else
		print("🎒 CLIENT MATH: No physical tool found in character model. Defaulting to bare hands (ToolPower: 1)")
	end

	-- Apply the exact game formula
	local finalDuration = (baseTime / toolPower) * localHasteMultiplier
	print(string.format("📊 CLIENT MATH CHECK: Base(%s) / ToolPower(%s) * HasteMult(%s) = Target Hold: %ss", 
		tostring(baseTime), tostring(toolPower), tostring(localHasteMultiplier), tostring(finalDuration)))

	return math.max(0.1, finalDuration)
end

