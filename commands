				local targetCells = getModelOccupiedCells(currentPreviewModel, previewBoundingCFrame.Position, previewBoundingSize)

				-- ===== DEBUG: HOW MANY CELLS DOES THE PREVIEW OCCUPY? =====
				-- print("📦 CLIENT DEBUG: Preview occupies " .. #targetCells .. " cells:")
				--for _, key in ipairs(targetCells) do
				--print("   → " .. key)
				--end
				-- ===== END DEBUG =====

				local surfaceInstance = targetPart:FindFirstAncestorOfClass("Model") or targetPart
				local isCellOccupied = false
				for _, key in ipairs(targetCells) do
					local v = OccupiedGrids[key]
					if v ~= nil and v ~= true and v ~= activePlacementBlockName and v ~= surfaceInstance then
						-- ===== DEBUG: WHICH CELL IS BLOCKING PLACEMENT? =====
						print("🚫 CLIENT DEBUG: Cell " .. key .. " is occupied by: " .. tostring(v))
						if typeof(v) == "Instance" then
							print("   Blocking instance name: " .. v.Name)
						end
						-- ===== END DEBUG =====
						isCellOccupied = true
						break
					end
				end

				local previewHasBoundaries = false
				for _, part in ipairs(currentPreviewModel:GetDescendants()) do
					if part:IsA("BasePart") and part.Name:match("^TransparentBoundary") then
						previewHasBoundaries = true
						break
					end
				end

				if not isCellOccupied and not previewHasBoundaries then
					local shrink = 0.01
					local pMin = previewBoundingCFrame.Position - previewBoundingSize / 2 + Vector3.new(shrink, shrink, shrink)
					local pMax = previewBoundingCFrame.Position + previewBoundingSize / 2 - Vector3.new(shrink, shrink, shrink)
					local activeMap = workspace:FindFirstChild("ActiveMap")
					if activeMap then
						for _, instance in ipairs(activeMap:GetChildren()) do
							-- 🆕 Skip blocks that use TransparentBoundary — their cells are already accurately registered
							local hasBoundaries = boundaryBlockCache[instance]
							if hasBoundaries == nil then
								hasBoundaries = false
								for _, part in ipairs(instance:GetDescendants()) do
									if part:IsA("BasePart") and part.Name:match("^TransparentBoundary") then
										hasBoundaries = true
										break
									end
								end
								boundaryBlockCache[instance] = hasBoundaries
							end
							if hasBoundaries then continue end
							local isSurface = instance == surfaceInstance
							local previewOverlapsSurface = false
							if isSurface then
								local bCFrame, bSize = instance:IsA("Model") and instance:GetBoundingBox() or CFrame.new(instance.Position), instance:IsA("Model") and select(2, instance:GetBoundingBox()) or instance.Size
								local bMin = bCFrame.Position - bSize / 2
								local bMax = bCFrame.Position + bSize / 2
								previewOverlapsSurface = pMin.X < bMax.X - shrink and pMax.X > bMin.X + shrink and
									pMin.Y < bMax.Y - shrink and pMax.Y > bMin.Y + shrink and
									pMin.Z < bMax.Z - shrink and pMax.Z > bMin.Z + shrink
							end
							if not isSurface or previewOverlapsSurface then
								local bCFrame, bSize = instance:IsA("Model") and instance:GetBoundingBox() or CFrame.new(instance.Position), instance:IsA("Model") and select(2, instance:GetBoundingBox()) or instance.Size
								local bMin = bCFrame.Position - bSize / 2
								local bMax = bCFrame.Position + bSize / 2
								if pMin.X < bMax.X and pMax.X > bMin.X and
									pMin.Y < bMax.Y and pMax.Y > bMin.Y and
									pMin.Z < bMax.Z and pMax.Z > bMin.Z then
									-- ===== DEBUG: OLD BOUNDING BOX CHECK IS BLOCKING =====
									--print("🚫 CLIENT DEBUG: OLD BOUNDING BOX CHECK blocked placement!")
									--print("   Blocking instance: " .. instance.Name)
									--print("   Preview min: " .. tostring(pMin) .. " max: " .. tostring(pMax))
									local bCFrame2, bSize2 = instance:IsA("Model") and instance:GetBoundingBox() or CFrame.new(instance.Position), instance:IsA("Model") and select(2, instance:GetBoundingBox()) or instance.Size
									--print("   Blocker min: " .. tostring(bCFrame2.Position - bSize2/2) .. " max: " .. tostring(bCFrame2.Position + bSize2/2))
									-- ===== END DEBUG =====
									isCellOccupied = true
									break
								end
							end
						end
					end
				end 
				-- 4. Check adjacency rule using the corrected coordinate bounds
				-- 4. Check adjacency rule: check directly behind the mouse hit point, not the shifted model cells
				local hasValidNeighbor = targetPart.Name == "Baseplate"
				if not hasValidNeighbor then
					local contactCell = snapToGrid(rawHit)
					local cellOffset = surfaceNormal * GRID_SIZE
					local cx, cy, cz = contactCell.X, contactCell.Y, contactCell.Z
					local behindKey = string.format("%d,%d,%d", cx - cellOffset.X, cy - cellOffset.Y, cz - cellOffset.Z)
					local contactKey = string.format("%d,%d,%d", cx, cy, cz)




					if OccupiedGrids[behindKey] ~= nil then
						hasValidNeighbor = true
						--print("✅ NEIGHBOR DEBUG: Found via behindKey")
					end
					if not hasValidNeighbor then
						if OccupiedGrids[contactKey] ~= nil then
							hasValidNeighbor = true
							--print("✅ NEIGHBOR DEBUG: Found via contactKey")
						end
					end
					if not hasValidNeighbor then
						--print("❌ NEIGHBOR DEBUG: Neither behindKey nor contactKey found. Checking distance fallback...")
						for _, v in pairs(OccupiedGrids) do
							if typeof(v) == "Instance" then
								local model = v:IsA("Model") and v or v.Parent
								if model then
									local modelCFrame, modelSize = model:GetBoundingBox()
									local modelPos = modelCFrame.Position
									local distance = (Vector3.new(cx, cy, cz) - modelPos).Magnitude
									if distance <= modelSize.Magnitude / 2 + GRID_SIZE then
										hasValidNeighbor = true
										break
									end
								end
							end
						end
					end
				end

				-- 5. 🎯 MULTI-CELL COLLISION FORBID ENGINE
				-- If ANY cell inside the footprint is occupied, we must treat the position as completely invalid
				if hasValidNeighbor and not isCellOccupied then
					canPlaceHere = true

					-- Turn preview model translucent white to indicate placement is completely clear
					for _, part in pairs(currentPreviewModel:GetDescendants()) do
						if part:IsA("BasePart") then
							part.Color = Color3.fromRGB(255, 255, 255)
							part.Transparency = 0 -- Fully opaque / visible
						end
					end

					-- Highlight target face part green
					SelectionBox.Color3 = Color3.fromRGB(75, 255, 75)
					SelectionBox.Adornee = targetPart
				else
					-- Forbids placement if there's no valid neighbor OR if any single cell is collided/blocked!
					canPlaceHere = false
					SelectionBox.Adornee = nil

					-- Turn preview model translucent RED to warn the builder of a structural collision
					for _, part in pairs(currentPreviewModel:GetDescendants()) do
						if part:IsA("BasePart") then
							part.Color = Color3.fromRGB(255, 75, 75)
							part.Transparency = 0.5
						end
					end
				end

				-- ENGINE BRANCH B: Holding a Mining Tool Mode (No Placement Active)
			elseif isHoldingValidMiningTool and targetPart:IsDescendantOf(workspace:WaitForChild("ActiveMap")) and targetPart.Name ~= "Baseplate" then
				canPlaceHere = false

				-- Turn the outline a clean white or light blue to show you are targeting a minable block
				SelectionBox.Color3 = Color3.fromRGB(255, 255, 255)

				-- If the part belongs to a Model block, outline the whole model. Otherwise outline the single part.
				local visualTarget = targetPart.Parent:IsA("Model") and targetPart.Parent or targetPart
				SelectionBox.Adornee = visualTarget
			else
				-- No valid tool held and not placing anything: Turn off outline completely
				canPlaceHere = false
				SelectionBox.Adornee = nil
			end
		else
			canPlaceHere = false
			if SelectionBox then SelectionBox.Adornee = nil end
		end
	else
		canPlaceHere = false
		if SelectionBox then SelectionBox.Adornee = nil end
	end
end)
