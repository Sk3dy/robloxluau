local function getMouseTarget()
	local targetPart = mouse.Target
	if not targetPart then return nil end

	local activeMapFolder = workspace:FindFirstChild("ActiveMap")
	if activeMapFolder and targetPart:IsDescendantOf(activeMapFolder) then
		local blockModel = targetPart:FindFirstAncestorOfClass("Model")
		if blockModel and blockModel.Parent == activeMapFolder then
			return blockModel 
		end
	end

	local current = targetPart
	while current and current ~= workspace do
		if current:GetAttribute("ItemRewardID") then return current end
		current = current.Parent
	end
	return nil
