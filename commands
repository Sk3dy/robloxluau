	-- 🛡️ MAGIC TRANSLATOR: Force it to be a real number!
	local itemNumber = tonumber(itemIdentifier)

	-- 🎯 Look up the item in our database using the NUMBER the server sent us
	if itemNumber and itemDatabase[itemNumber] then
		local itemData = itemDatabase[itemNumber]
		local existingStack = nil

		-- 1. Check if we already have this item to stack it
		for i = 1, 72 do
			local slotCheck = getSlot(i)
			if slotCheck then
				local itemFrame = slotCheck:FindFirstChild(itemData.name)
				if itemFrame then 
					existingStack = itemFrame 
					break 
				end
			end
		end

		if existingStack then
			local currentAmount = existingStack:GetAttribute("Amount") or 1
			local newAmount = currentAmount + spawnAmount
			existingStack:SetAttribute("Amount", newAmount)
			local countLabel = existingStack:FindFirstChild("CountLabel")
			if countLabel then
				countLabel.Text = tostring(newAmount)
				countLabel.Visible = true
			end
			-- Tell the server to save the CORRECT NAME (e.g., "Dirt", not "Infinite Dirt")
			SaveInventoryEvent:FireServer("UpdateSlot", existingStack.Parent.Name, existingStack.Name, newAmount)
			return
		end

		-- 2. If we don't have it, find an empty slot
		local targetSlot = nil
		for i = 1, 72 do
			local slotCheck = getSlot(i)
			if slotCheck then
				local hasAnItem = false
				for _, child in ipairs(slotCheck:GetChildren()) do
					if child:IsA("Frame") and child.Name ~= "Background" then
						hasAnItem = true
						break
					end
				end
				if not hasAnItem then 
					targetSlot = slotCheck 
					break 
				end
			end
		end

		-- 3. Create the visual and tell the server to save it
		if targetSlot then
			local newItem = createItemVisual(itemData.name, itemData.color, targetSlot, spawnAmount)
			makeElementDraggable(newItem)
			-- Tell the server to save the CORRECT NAME
			SaveInventoryEvent:FireServer("UpdateSlot", targetSlot.Name, newItem.Name, spawnAmount)
		end
	else
		warn("⚠️ Client could not find item in database for Number ID: " .. tostring(itemNumber))
	end
end)

