local function rebuildOccupiedGrids()
	print("🔄 Scanning ActiveMap to rebuild Occupied Grids...")
	OccupiedGrids = {} -- Clear the old list first

	local activeMap = workspace:FindFirstChild("ActiveMap")
	if not activeMap then 
		warn("⚠️ ActiveMap folder not found! Cannot rebuild grids.")
		return 
	end

	for _, instance in ipairs(activeMap:GetChildren()) do
		local boundingCFrame, boundingSize
		if instance:IsA("Model") then
			boundingCFrame, boundingSize = instance:GetBoundingBox()
		elseif instance:IsA("BasePart") then
			boundingCFrame = CFrame.new(instance.Position)
			boundingSize = instance.Size
		else
			continue -- Skip anything that isn't a Model or Part
		end

		local blockCenter = Vector3.new(
			math.round(boundingCFrame.Position.X / GRID_SIZE) * GRID_SIZE,
			math.round(boundingCFrame.Position.Y / GRID_SIZE) * GRID_SIZE,
			math.round(boundingCFrame.Position.Z / GRID_SIZE) * GRID_SIZE
		)

		local cells = getOccupiedCells(blockCenter, boundingSize)
		for _, key in ipairs(cells) do
			OccupiedGrids[key] = instance
		end
	end
	print("✅ Occupied Grids successfully rebuilt! (" .. #activeMap:GetChildren() .. " items scanned)")
end

