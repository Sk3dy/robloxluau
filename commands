-- 3. INTERACTIVE REGISTER FOR DRAGS
local function makeElementDraggable(itemFrame)
	itemFrame.InputBegan:Connect(function(input)
		if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and not draggingItem then
			draggingItem = itemFrame
			mousePos = input.Position
			startPos = itemFrame.Position
			originalParent = itemFrame.Parent

			itemFrame.ZIndex = 100 
			if itemFrame:FindFirstChildOfClass("TextLabel") then
				itemFrame:FindFirstChildOfClass("TextLabel").ZIndex = 101
			end

			print("--- DRAG STARTED: " .. itemFrame.Name .. " ---")
		end
	end)

	itemFrame.InputChanged:Connect(function(input)
		if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) and draggingItem == itemFrame then
			dragInput = input
		end
	end)
end

UserInputService.InputChanged:Connect(function(input)
	if input == dragInput and draggingItem then
		local delta = input.Position - mousePos
		draggingItem.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and draggingItem then
		local itemFrame = draggingItem
		draggingItem = nil
		dragInput = nil

		itemFrame.ZIndex = 2
		if itemFrame:FindFirstChildOfClass("TextLabel") then
			itemFrame:FindFirstChildOfClass("TextLabel").ZIndex = 3
		end

		print("--- DRAG ENDED / PROCESSING DROP ---")

		local itemAbsPos = itemFrame.AbsolutePosition
		local itemAbsSize = itemFrame.AbsoluteSize
		local itemCenterX = itemAbsPos.X + (itemAbsSize.X / 2)
		local itemCenterY = itemAbsPos.Y + (itemAbsSize.Y / 2)

		local droppedInSlot = false
		local allUIObjects = screengui:GetDescendants()

		for _, obj in ipairs(allUIObjects) do
			if obj:IsA("Frame") then
				local name = obj.Name:lower()

				if name:match("^hotbar%d+") or name:match("^inventory%d+") or name:match("^chest%d+") then
					local absPos = obj.AbsolutePosition
					local absSize = obj.AbsoluteSize

					local minX, maxX = absPos.X - 15, absPos.X + absSize.X + 15
					local minY, maxY = absPos.Y - 15, absPos.Y + absSize.Y + 15

					if itemCenterX >= minX and itemCenterX <= maxX and itemCenterY >= minY and itemCenterY <= maxY then
						print("🎯 Dropped over slot:", obj.Name)
						droppedInSlot = true

						local existingItem = nil
						for _, child in ipairs(obj:GetChildren()) do
							if child:IsA("Frame") and child ~= itemFrame then
								existingItem = child
								break
							end
						end

						if existingItem then
							if existingItem.Name == itemFrame.Name then
								local currentAmount = existingItem:GetAttribute("Amount") or 1
								local draggedAmount = itemFrame:GetAttribute("Amount") or 1
								local newAmount = currentAmount + draggedAmount

								existingItem:SetAttribute("Amount", newAmount)
								local countLabel = existingItem:FindFirstChild("CountLabel")
								if countLabel then
									countLabel.Text = tostring(newAmount)
									countLabel.Visible = true
								end

								SaveInventoryEvent:FireServer("UpdateSlot", originalParent.Name, nil, nil)
								SaveInventoryEvent:FireServer("UpdateSlot", obj.Name, existingItem.Name, newAmount)

								itemFrame:Destroy()
								break
							else
								existingItem.Parent = originalParent
								existingItem.Position = UDim2.new(0, 0, 0, 0)

								itemFrame.Parent = obj
								itemFrame.Position = UDim2.new(0, 0, 0, 0)

								SaveInventoryEvent:FireServer("UpdateSlot", originalParent.Name, existingItem.Name, existingItem:GetAttribute("Amount"))
								SaveInventoryEvent:FireServer("UpdateSlot", obj.Name, itemFrame.Name, itemFrame:GetAttribute("Amount"))
								break
							end
						else
							if originalParent and originalParent ~= obj then
								SaveInventoryEvent:FireServer("UpdateSlot", originalParent.Name, nil, nil)
							end

							itemFrame.Parent = obj 
							itemFrame.Position = UDim2.new(0, 0, 0, 0) 

							SaveInventoryEvent:FireServer("UpdateSlot", obj.Name, itemFrame.Name, itemFrame:GetAttribute("Amount"))
							break
						end
					end
				end
			end
		end

		if not droppedInSlot then
			print("❌ Drop missed target boundaries. Returning to original position.")
			itemFrame.Parent = originalParent
			itemFrame.Position = UDim2.new(0, 0, 0, 0)
		end
	end
end)

