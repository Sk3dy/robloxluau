SaveInventoryEvent.OnClientEvent:Connect(function(action, savedData)
	print("🔍 DEBUG: SaveInventoryEvent fired with action:", action)

	if action == "Load" and savedData then
		print("📦 Received Save Data from Server. Contents:", savedData)

		-- [ORIGINAL RESTORATION LOOP]
		for slotName, itemInfo in pairs(savedData) do
			local targetSlot = screengui:FindFirstChild(slotName, true)
			if targetSlot and targetSlot:IsA("Frame") then
				if itemInfo == "Clear" then
					print("🧹 ↳ Clear Request: Wiping visual item frames from slot: " .. slotName)
					for _, child in ipairs(targetSlot:GetChildren()) do
						if child:IsA("Frame") or child:IsA("TextLabel") or child:IsA("ImageLabel") then
							child:Destroy()
						end
					end
				elseif type(itemInfo) == "table" and itemInfo.name then
					local itemName = itemInfo.name
					local itemAmount = itemInfo.amount or 1
					print("  ↳ ✅ Restoring: " .. itemName .. " x" .. tostring(itemAmount) .. " into slot: " .. slotName)
					for _, child in ipairs(targetSlot:GetChildren()) do
						if child:IsA("Frame") or child:IsA("TextLabel") then
							child:Destroy()
						end
					end
					local matchedData = nil
					for _, data in pairs(itemDatabase) do
						if data.name == itemName then matchedData = data break end
					end
					if matchedData then
						local loadedItem = createItemVisual(matchedData.name, matchedData.color, targetSlot, itemAmount)
						makeElementDraggable(loadedItem)
					end
				end
			end
		end

		-- 🛡️ SAFETY CHECK: Did we just run out of the item we are currently using?
		local itemWeAreUsing = ""
		if activePlacementBlockName ~= "" then
			itemWeAreUsing = activePlacementBlockName
		elseif activeEquippedItemName ~= "" then
			itemWeAreUsing = activeEquippedItemName
		end

		print("🔍 DEBUG: Client thinks it is currently trying to place/use:", itemWeAreUsing)

		if itemWeAreUsing ~= "" then
			-- 🛡️ SMART FILTER: If it's a tool or potion, SKIP the "ran out" check entirely!
			local isTool = ToolsStorage:FindFirstChild(itemWeAreUsing) ~= nil

			if isTool then
				print("✅ DEBUG: Item is a tool/potion. Skipping 'ran out' check to prevent accidental unequip.")
			else
				local stillHaveItem = false

				-- Look through all our inventory slots to see if we still have this block
				for slotName, itemInfo in pairs(savedData) do
					if type(itemInfo) == "table" and itemInfo.name == itemWeAreUsing and (itemInfo.amount or 0) > 0 then
						stillHaveItem = true
						print("🔍 DEBUG: Found " .. itemWeAreUsing .. " in slot " .. slotName .. " with amount: " .. itemInfo.amount)
						break
					elseif itemInfo == "Clear" then
						print("🔍 DEBUG: Slot " .. slotName .. " was cleared by server.")
					end
				end

				-- If we DON'T have it anymore, force stop everything!
				if not stillHaveItem then
					print("⚠️ RAN OUT OF BLOCK! Auto-unequipping and stopping placement for: " .. itemWeAreUsing)
					currentlySelectedSlot = nil
					activeEquippedItemName = ""
					stopPlacementMode() -- This deletes the ghost block
					MineResourceEvent:FireServer("EQUIP_TOOL_ACTION", "Clear") -- This tells server we have nothing equipped
				else
					print("✅ DEBUG: We still have the item, or it wasn't the one we were placing.")
				end
			end
		end
	end
end)

TextChatService.OnIncomingMessage = function(message)
	if message.TextSource and message.TextSource.UserId == player.UserId and message.Status == Enum.TextChatMessageStatus.Success then
		local chatText = message.Text

		-- 🆕 Admin-only commands check (moved here so it doesn't block the whole script)
		if not admins[player.UserId] then return end

		if string.sub(chatText, 1, 8) == "/additem" then
			local argumentsText = string.sub(chatText, 9) 
			local args = string.split(argumentsText, " ")

			local cleanArgs = {}
			for _, v in ipairs(args) do
				if v ~= "" then table.insert(cleanArgs, v) end
			end

			local itemNumber = tonumber(cleanArgs[1])
			local spawnAmount = tonumber(cleanArgs[2]) or 1 

			if itemNumber and itemDatabase[itemNumber] then
				local itemData = itemDatabase[itemNumber]

				local existingStack = nil
				local targetSlot = nil
				for i = 1, 72 do
					local slotCheck = getSlot(i)
					if slotCheck then
						local itemFrame = slotCheck:FindFirstChild(itemData.name)
						if itemFrame then existingStack = itemFrame break end
					end
				end
				for i = 1, 72 do
					local slotCheck = getSlot(i)
					if slotCheck then
						local hasAnItem = false
						for _, child in ipairs(slotCheck:GetChildren()) do
							if child:IsA("Frame") and child.Name ~= "Background" then
								hasAnItem = true
								break
							end
						end
						if not hasAnItem then targetSlot = slotCheck break end
					end
				end

				if existingStack then
					local currentAmount = existingStack:GetAttribute("Amount") or 1
					local newAmount = currentAmount + spawnAmount

					existingStack:SetAttribute("Amount", newAmount)
					local countLabel = existingStack:FindFirstChild("CountLabel")
					if countLabel then
						countLabel.Text = tostring(newAmount)
						countLabel.Visible = true
					end

					SaveInventoryEvent:FireServer("UpdateSlot", existingStack.Parent.Name, existingStack.Name, newAmount)
					return
				end

				local targetSlot = nil
				for i = 1, 72 do
					local slotCheck = getSlot(i)
					if slotCheck then
						local hasAnItem = false
						for _, child in ipairs(slotCheck:GetChildren()) do
							if child:IsA("Frame") and child.Name ~= "Background" then
								hasAnItem = true
								break
							end
						end
						if not hasAnItem then targetSlot = slotCheck break end
					end
				end

				if targetSlot then
					local newItem = createItemVisual(itemData.name, itemData.color, targetSlot, spawnAmount)
					makeElementDraggable(newItem)
					SaveInventoryEvent:FireServer("UpdateSlot", targetSlot.Name, newItem.Name, spawnAmount)
				end
			end
			-- 🦅 FLY COMMAND
		elseif string.sub(chatText, 1, 5) == "/fly" then
			isFlying = not isFlying -- Flip the switch (true becomes false, false becomes true)
			local character = player.Character
			local humanoid = character and character:FindFirstChildOfClass("Humanoid")

			if humanoid then
				humanoid.PlatformStand = isFlying
				if isFlying then
					print("🦅 Fly Mode: ENABLED! Use W, A, S, D, Space (Up), and Shift (Down) to move.")
				else
					print("🚶 Fly Mode: DISABLED. Normal walking restored.")
				end
			end
		end


	end

end

