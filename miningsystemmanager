local ReplicatedStorage = game:GetService("ReplicatedStorage")
local MineResourceEvent = ReplicatedStorage:WaitForChild("MineResourceEvent")
local SaveInventoryEvent = ReplicatedStorage:WaitForChild("SaveInventory")
local ItemTemplates = ReplicatedStorage:WaitForChild("ItemTemplates")

